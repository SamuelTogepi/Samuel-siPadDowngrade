    mkdir -p data/ipsw

    if [ "$os" = "Linux" ]; then
        # On Linux we need root.
        if [ "$EUID" -ne 0 ]; then
            echo "Error: a999 must be ran with root privileges on Linux. Please execute it with sudo or as the root user to continue."
            exit 1
        fi
    fi

    if [ ! -f "bin/Legacy-iOS-Kit/resources/firstrun" ]; then
        (cd bin/Legacy-iOS-Kit && ./restore.sh --no-version-check --no-internet-check)
        # This is to account for LibUSB being just installed.

        if [ "$os" = "Linux" ]; then
            if command -v dnf >/dev/null; then
                # More deps.
                dnf install -y libimobiledevice libimobiledevice-utils expect idevicerestore irecovery
                # Crypto libraries for lockdown.
                update-crypto-policies --set LEGACY > /dev/null 2>&1
                echo "Fedora users may need to reboot now before running a999 again! If it doesn't work, reboot and try again."

            elif command -v apt >/dev/null; then
                apt install --yes expect libimobiledevice libimobiledevice-utils expect idevicerestore irecovery
            fi
        fi

        read -p "Please disconnect then reconnect your USB-A Lightning cable to ensure the iPa can be detected.Then press any key to continue..."
    fi

    # Additional setup.
    if [ "$os" = "Linux" ]; then
        # https://github.com/alex-free/a999activator/issues/8#issuecomment-3383734504
        if command -v dnf >/dev/null; then
            # Crypto libraries for lockdown.
            update-crypto-policies --set LEGACY > /dev/null 2>&1
            # Crypto policies usually require a reboot to take effect but let's just be thorough here...
            # Set SE linux to permissive (resets on Reboot)
            setenforce 0
        fi
    elif [ "$os" = "Darwin" ]; then
        # All these executables are signed so that is the only think preventing gatekeeper from allowing the script to be automatic is the quarintine attributes.
        # Remove any quarintine attributes in this folder.
        xattr -rc .
    else
        echo "Error: unsupported operating system!"
        exit 1
    fi
}

detect_ipad() {

# ---------------------------------------------------------
# iPad Detection & Environment Setup
# Models Supported: iPad 5, 6, Pro 9.7, Pro 10.5, Pro 12.9
# ---------------------------------------------------------

scan_for_ipad() {
    # Initialize usbmuxd in polling mode on Linux for better detection
    if [[ "$SYS_OS" == "Linux" ]]; then
        usbmuxd_restart_polling > /dev/null 2>&1
    fi

    echo "Scanning for a compatible A9 or A10 iPad via USB-A..."

    # DFU mode check: Serial Number isn't visible here, so we must exit to Recovery
    if irecovery -m 2>/dev/null | grep -q "DFU Mode"; then
        echo "Device is currently in DFU Mode. Please reboot it into Recovery Mode to continue."
        await_recovery_mode
    fi

    # Detection Loop
    while true; do
        if irecovery -m 2>/dev/null | grep -q "Recovery Mode"; then
            echo "Status: iPad identified in Recovery Mode."
            IS_RECOVERY_PHASE=true
            
            # Extract hardware details
            local rec_data=$(irecovery -q 2>/dev/null)
            SERIAL_NUM=$(echo "$rec_data" | grep 'SRNM:' | awk '{print $2}')
            local prod_id=$(echo "$rec_data" | grep 'PRODUCT:' | awk '{print $2}')
            local cpid_id=$(echo "$rec_data" | grep 'CPID:' | awk '{print $2}')

            case "$prod_id" in
                "iPad6,11"|"iPad6,12") IPAD_MODEL="iPad_5th_Gen" ;;
                "iPad7,5"|"iPad7,6")   IPAD_MODEL="iPad_6th_Gen" ;;
                "iPad6,7"|"iPad6,8")   IPAD_MODEL="iPad_Pro_12.9_1st_Gen" ;;
                "iPad6,3"|"iPad6,4")   IPAD_MODEL="iPad_Pro_9.7" ;;
                "iPad7,1"|"iPad7,2")   IPAD_MODEL="iPad_Pro_12.9_2nd_Gen" ;;
                "iPad7,3"|"iPad7,4")   IPAD_MODEL="iPad_Pro_10.5" ;;
                *) echo "Error: Detected unsupported hardware ($prod_id)."; exit 1 ;;
            esac

            # Log Chip Architecture
            case "$cpid_id" in
                "0x8003"|"0x8000") echo "Chipset: A9 detected." ;;
                "0x8001")          echo "Chipset: A9X (iPad Pro) detected." ;;
                "0x8010"|"0x8011") echo "Chipset: A10/A10X detected." ;;
            esac
            break

        else
            echo "Checking for iPad in Normal (Springboard) Mode..."
            idevicepair pair >/dev/null 2>&1
            
            # Efficiently grab specific keys using -k
            SERIAL_NUM=$(ideviceinfo -k SerialNumber 2>/dev/null)
            local model_type=$(ideviceinfo -k ProductType 2>/dev/null)
            local hw_plat=$(ideviceinfo -k HardwarePlatform 2>/dev/null)

            if [[ -n "$model_type" ]]; then
                case "$model_type" in
                    "iPad6,11"|"iPad6,12") IPAD_MODEL="iPad_5th_Gen" ;;
                    "iPad7,5"|"iPad7,6")   IPAD_MODEL="iPad_6th_Gen" ;;
                    "iPad6,7"|"iPad6,8")   IPAD_MODEL="iPad_Pro_12.9_1st_Gen" ;;
                    "iPad6,3"|"iPad6,4")   IPAD_MODEL="iPad_Pro_9.7" ;;
                    "iPad7,1"|"iPad7,2")   IPAD_MODEL="iPad_Pro_12.9_2nd_Gen" ;;
                    "iPad7,3"|"iPad7,4")   IPAD_MODEL="iPad_Pro_10.5" ;;
                    *) echo "Unsupported iPad model: $model_type"; exit 1 ;;
                esac
                
                # Verify chipset architecture
                [[ "$hw_plat" == *"s8000"* || "$hw_plat" == *"s8003"* || "$hw_plat" == *"s8001"* ]] && IS_A9_CHIP=true
                break
            fi
        fi
        sleep 2
    done

    # Final logic for A9 flag
    if [[ "$IPAD_MODEL" == *"iPad_5th_Gen"* || "$IPAD_MODEL" == *"iPad_Pro_9.7"* || "$IPAD_MODEL" == *"iPad_Pro_12.9_1st_Gen"* ]]; then
        IS_A9_CHIP=true
    fi

    echo "------------------------------------------------"
    echo " Target: $IPAD_MODEL"
    echo " Serial: $SERIAL_NUM"
    echo " Arch:   $( [[ "$IS_A9_CHIP" == "true" ]] && echo "A9/A9X" || echo "A10/A10X" )"
    echo "------------------------------------------------"
}

# Prevents the iPad from auto-booting into iOS after a failed exploit
restrict_auto_boot() {
    echo "Configuring environment variables to prevent auto-boot..."
    irecovery -c "setenv auto-boot false"

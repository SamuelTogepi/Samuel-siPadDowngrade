initiate_firmware_restore() {
    local ipsw_path="$1"
    
    # Prepare the environment
    await_recovery_mode
    restrict_auto_boot
    parse_firmware_details "$ipsw_path"

    echo "Status: Preparing to install iOS $FIRMWARE_VER..."

    # Define the workspace for this specific device/firmware combo
    local session_dir="data/${IPAD_MODEL}_${SERIAL_NUM}/${FIRMWARE_VER}"
    mkdir -p "$session_dir/block"

    if [[ "$IS_A9_CHIP" == "true" ]]; then
        # --- A9/A9X Logic (iPad 5, Pro 9.7, Pro 12.9 Gen 1) ---

        # 1. Acquire Restore SHCBlock
        # We check for the specific bin file needed to authorize the restore
        while ! ls "$session_dir"/block/*-restore-shcblock2.bin >/dev/null 2>&1; do
            echo "Step 1: Fetching Restore SHCBlock..."
            run_exploit_sequence # formerly turdursra1n_pwn

            if ! echo 1 | turdus_merula -C "$session_dir" --get-shcblock "$ipsw_path"; then
                echo "Warning: Block acquisition failed. Retrying exploit..."
                continue
            fi

            await_recovery_mode
            restrict_auto_boot
        done

        # 2. Execute the Restore
        echo "Step 2: Installing firmware to iPad..."
        run_exploit_sequence

        until echo 1 | turdus_merula -C "$session_dir" -o --load-shcblock "$session_dir"/block/*-restore-shcblock2.bin "$ipsw_path"; do
            echo "Restore interrupted. Restarting exploit..."
            run_exploit_sequence
        done

        # If this is just a bridge restore (e.g., 10.3.3), we stop here.
        if [[ "$IS_PRELIMINARY_RESTORE" == "true" ]]; then
            echo "Bridge restore complete."
            return
        fi

        # 3. Acquire Post-Restore (Current) SHCBlock
        # Required for final tethered boot generation
        while ! ls "$session_dir"/block/*-current-shcblock2.bin >/dev/null 2>&1; do
            echo "Step 3: Fetching post-install SHCBlock..."
            
            # Use subshell to handle directory jumping safely
            (
                cd "$session_dir" || exit
                until turdusra1n -g "$ipsw_path"; do
                    echo "Retrying block dump..."
                done
            )

            await_recovery_mode
            restrict_auto_boot
        done

        # 4. Generate PTEBlock (The Tethered Boot Key)
        while ! ls "$session_dir"/block/*-pteblock2.bin >/dev/null 2>&1; do
            echo "Step 4: Generating PTEBlock for tethered booting..."
            
            (
                cd "$session_dir" || exit
                # Attempt to generate PTEBlock using the signed SEP and current SHC
                until turdusra1n -g -i image4/*signed-SEP.img4 -C block/*-current-shcblock2.bin "$ipsw_path"; do
                    echo "PTE Generation failed. Retrying..."
                done
            )

            await_recovery_mode
            restrict_auto_boot
        done

    else
        # --- A10/A10X Logic (iPad 6, Pro 10.5, Pro 12.9 Gen 2) ---
        echo "Step 1: Commencing A10/A10X Restore Sequence..."
        run_exploit_sequence

        until echo 1 | turdus_merula -C "$session_dir" -o "$ipsw_path"; do
            echo "Error during A10 restore. Re-exploiting..."
            run_exploit_sequence
        done
    fi

    echo "Firmware installation sequence finished."
}

boot_turdusra1n() {
    # Ensure the device is reachable in recovery before starting
    await_recovery_mode

    # We stay in this loop as long as the iPad is detected in Recovery Mode.
    # Logic: turdusra1n sometimes returns a '0' exit code (success) even if 
    # the boot fails to reach the kernel. Monitoring the recovery state 
    # is the only reliable way to confirm the iPad has actually started iOS.
    while irecovery -m 2>/dev/null | grep -q "Recovery Mode"; do
        echo "Guidance: If a 'failed to open handle' error appears after Checkmate, try unplugging and re-plugging the USB cable."

        local base_path="data/${IPAD_MODEL}_${SERIAL_NUM}/${FIRMWARE_VER}"

        if [[ "$IS_A9_CHIP" == "true" ]]; then
            # Boot Sequence for A9/A9X (iPad 5, iPad Pro 9.7, iPad Pro 12.9 Gen 1)
            until turdusra1n -TP "$base_path"/block/*-pteblock2.bin; do
                echo "System failed to boot. Re-trying exploit..."
                sleep 1
            done
        else
            # Boot Sequence for A10/A10X (iPad 6, iPad Pro 10.5, iPad Pro 12.9 Gen 2)
            # Requires the iBoot image and both signed and unsigned SEP components
            until turdusra1n -t "$base_path"/image4/*iBoot.img4 \
                             -i "$base_path"/image4/*signed-SEP.img4 \
                             -p "$base_path"/image4/*-SEP.im4p; do
                echo "System failed to boot. Re-trying exploit..."
                sleep 1
            done
        fi

        # Allow sufficient time for the iPad to initialize the kernel and 
        # disconnect from the recovery stack.
        echo "Exploit payload sent. Waiting 20 seconds to verify system handoff..."
        sleep 20
    done

    echo "Status: iPad has successfully exited Recovery Mode."
}


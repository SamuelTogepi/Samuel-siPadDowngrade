#!/bin/bash

# ============================================================
# Samuel's iPad Downgrade
# Targeted for A9/A10/A10X iPads
# Version: 1.0.0
# ============================================================

SAM_VER="1.0.0"
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$BASE_DIR"

# Enable logging via Process Substitution
exec > >(tee session_log.txt) 2>&1

# --- Global Variables ---
SYS_OS="$(uname)"
SYS_ARCH="$(uname -m)"
IPAD_MODEL=""
IS_A9_CHIP=false
FIRMWARE_VER=""
BOOT_VER=""
SERIAL_NUM=""
IS_IN_RECOVERY=false
IS_PRELIMINARY_RESTORE=true

echo "================================================"
echo "    Samuel's iPad Downgrade Utility v$SAM_VER"
echo "================================================"

# ============================================================
# 1. HELPER UTILITIES
# ============================================================

refresh_usbmux() {
    killall usbmuxd > /dev/null 2>&1
    usbmuxd > /dev/null 2>&1
}

pair_ipad(){
    idevicepair pair >/dev/null 2>&1
}

restrict_auto_boot() {
    echo "Configuring environment to prevent auto-booting..."
    irecovery -c "setenv auto-boot false"
    irecovery -c "saveenv"
}

await_recovery_mode() {
    until irecovery -m 2>/dev/null | grep -q "Recovery Mode"; do
        if irecovery -m 2>/dev/null | grep -q "DFU Mode"; then
            echo "Action Required: iPad is in DFU Mode. Please manually reboot it into Recovery Mode using the hardware buttons."
        fi
        sleep 1
    done
}

run_exploit_sequence() {
    await_recovery_mode
    until turdusra1n -D; do
        echo "Exploit failed. Re-attempting..."
        sleep 1
    done
}

parse_firmware_details() {
    local ipsw_file="$1"
    # Extracts the version and build string (e.g., 10.3.3_14G60)
    FIRMWARE_VER=$(echo "$ipsw_file" | sed -E 's/.*_(.*_.*)_Restore\.ipsw/\1/')
    # Extracts just the version string (e.g., 10.3.3) for A10 boot scripts
    BOOT_VER=$(echo "$ipsw_file" | sed -E 's/.*_(.*)_(.*)_Restore\.ipsw/\1/')
}

# ============================================================
# 2. ENVIRONMENT SETUP
# ============================================================

set_path() {
    local bin_base="$BASE_DIR/bin"
    local legacy_base="$bin_base/Legacy-iOS-Kit/bin"
    
    if [[ "$SYS_OS" == "Linux" ]]; then
        if [[ "$SYS_ARCH" == "x86_64" ]]; then
            PATH="${PATH:+$PATH:}$bin_base:$legacy_base/linux/x86_64:$bin_base/turdus_m3rula_1.1_b0ea3ee7_linux-amd64/bin"
        elif [[ "$SYS_ARCH" == "arm64" ]]; then
            PATH="${PATH:+$PATH:}$bin_base:$legacy_base/linux/arm64:$bin_base/turdus_m3rula_1.1_b0ea3ee7_linux-arm64/bin"
        else
            echo "Error: Linux architecture $SYS_ARCH is not supported."
            exit 1
        fi
        echo "Configured environment for Linux ($SYS_ARCH)."
    elif [[ "$SYS_OS" == "Darwin" ]]; then
        PATH="${PATH:+$PATH:}$bin_base:$legacy_base/macos:$bin_base/turdus_m3rula_1.1_b0ea3ee7_macos/bin"
        echo "Configured environment for macOS."
    else
        echo "Error: Operating system $SYS_OS is not supported."
        exit 1
    fi
}

startup() {
    [[ ! -d data ]] && mkdir data && echo "Workspace initialized." || echo "Found existing data folder."
    mkdir -p data/ipsw

    if [[ "$SYS_OS" == "Linux" ]]; then
        if [[ "$EUID" -ne 0 ]]; then
            echo "Error: Samuel's iPad Downgrade requires root privileges on Linux. Run with sudo."
            exit 1
        fi
    fi

    if [[ ! -f "bin/Legacy-iOS-Kit/resources/firstrun" ]]; then
        (cd bin/Legacy-iOS-Kit && ./restore.sh --no-version-check --no-internet-check)

        if [[ "$SYS_OS" == "Linux" ]]; then
            if command -v dnf >/dev/null; then
                dnf install -y libimobiledevice libimobiledevice-utils expect idevicerestore irecovery
                update-crypto-policies --set LEGACY > /dev/null 2>&1
                echo "Fedora users: If the script hangs, reboot your PC and try again."
            elif command -v apt >/dev/null; then
                apt update && apt install -y expect libimobiledevice libimobiledevice-utils idevicerestore irecovery
            fi
        fi

        echo "Dependencies installed. Disconnect and reconnect your iPad's USB cable, then press Enter."
        read -r
    fi

    # Fix OS-specific permissions
    if [[ "$SYS_OS" == "Linux" && -x "$(command -v dnf)" ]]; then
        update-crypto-policies --set LEGACY > /dev/null 2>&1
        setenforce 0 2>/dev/null
    elif [[ "$SYS_OS" == "Darwin" ]]; then
        xattr -rc .
    fi
}

update_existing_data() {
    if [[ -d "$1/data" ]]; then
        echo "Migrating data from $1..."
        cp -rv "$1/data" .
    else
        echo "Error: Could not locate the data folder in $1."
        exit 1
    fi
    cp -rv "$1"/boot-* . 2>/dev/null 
}

# ============================================================
# 3. CORE LOGIC
# ============================================================

scan_for_ipad() {
    if [[ "$SYS_OS" == "Linux" ]]; then
        usbmuxd_restart_polling > /dev/null 2>&1
    fi

    echo "Scanning for a compatible A9 or A10 iPad via USB..."

    if irecovery -m 2>/dev/null | grep -q "DFU Mode"; then
        echo "Device is currently in DFU Mode. Please reboot it into Recovery Mode."
        await_recovery_mode
    fi

    while true; do
        if irecovery -m 2>/dev/null | grep -q "Recovery Mode"; then
            echo "Status: iPad identified in Recovery Mode."
            IS_IN_RECOVERY=true
            
            local rec_data=$(irecovery -q 2>/dev/null)
            SERIAL_NUM=$(echo "$rec_data" | grep 'SRNM:' | awk '{print $2}')
            local prod_id=$(echo "$rec_data" | grep 'PRODUCT:' | awk '{print $2}')
            local cpid_id=$(echo "$rec_data" | grep 'CPID:' | awk '{print $2}')

            case "$prod_id" in
                "iPad6,11"|"iPad6,12") IPAD_MODEL="iPad_5th_Gen" ;;
                "iPad7,5"|"iPad7,6")   IPAD_MODEL="iPad_6th_Gen" ;;
                "iPad6,7"|"iPad6,8")   IPAD_MODEL="iPad_Pro_12.9_1st_Gen" ;;
                "iPad6,3"|"iPad6,4")   IPAD_MODEL="iPad_Pro_9.7" ;;
                "iPad7,1"|"iPad7,2")   IPAD_MODEL="iPad_Pro_12.9_2nd_Gen" ;;
                "iPad7,3"|"iPad7,4")   IPAD_MODEL="iPad_Pro_10.5" ;;
                *) echo "Error: Detected unsupported hardware ($prod_id)."; exit 1 ;;
            esac

            case "$cpid_id" in
                "0x8003"|"0x8000"|"0x8001") IS_A9_CHIP=true ;;
            esac
            break

        else
            echo "Checking for iPad in Normal (Springboard) Mode..."
            pair_ipad
            
            SERIAL_NUM=$(ideviceinfo -k SerialNumber 2>/dev/null)
            local model_type=$(ideviceinfo -k ProductType 2>/dev/null)
            local hw_plat=$(ideviceinfo -k HardwarePlatform 2>/dev/null)

            if [[ -n "$model_type" ]]; then
                case "$model_type" in
                    "iPad6,11"|"iPad6,12") IPAD_MODEL="iPad_5th_Gen" ;;
                    "iPad7,5"|"iPad7,6")   IPAD_MODEL="iPad_6th_Gen" ;;
                    "iPad6,7"|"iPad6,8")   IPAD_MODEL="iPad_Pro_12.9_1st_Gen" ;;
                    "iPad6,3"|"iPad6,4")   IPAD_MODEL="iPad_Pro_9.7" ;;
                    "iPad7,1"|"iPad7,2")   IPAD_MODEL="iPad_Pro_12.9_2nd_Gen" ;;
                    "iPad7,3"|"iPad7,4")   IPAD_MODEL="iPad_Pro_10.5" ;;
                    *) echo "Unsupported iPad model: $model_type"; exit 1 ;;
                esac
                
                [[ "$hw_plat" == *"s8000"* || "$hw_plat" == *"s8003"* || "$hw_plat" == *"s8001"* ]] && IS_A9_CHIP=true
                break
            fi
        fi
        sleep 2
    done

    echo "------------------------------------------------"
    echo " Target: $IPAD_MODEL"
    echo " Serial: $SERIAL_NUM"
    echo " Arch:   $( [[ "$IS_A9_CHIP" == "true" ]] && echo "A9/A9X" || echo "A10/A10X" )"
    echo "------------------------------------------------"
}

evaluate_prerequisite_restore() {
    parse_firmware_details "$1"

    case "$FIRMWARE_VER" in
        "10.0.1_14A403" | "10.0.2_14A456" | "10.0.3_14A551" | \
        "10.1_14B72c"   | "10.1.1_14B100" | "10.1.1_14B150" | \
        "10.2_14C92"    | "10.2.1_14D27"  | "10.3_14E277"   | \
        "10.3.1_14E304" | "10.3.2_14F89")
            echo "Notice: Early iOS 10 detected. A bridge restore to 10.3.3 is required."
            ;;
        *)
            return
            ;;
    esac

    local bridge_url=""
    case "$IPAD_MODEL" in
        "iPad_5th_Gen")          bridge_url="http://appldnld.apple.com/ios10.3.3/091-23331-20170719-CA996666-6977-11E7-81A4-399100BA0AE3/iPad_6,11_iPad_6,12_10.3.3_14G60_Restore.ipsw" ;;
        "iPad_Pro_12.9_1st_Gen") bridge_url="http://appldnld.apple.com/ios10.3.3/091-23269-20170719-CA961588-6977-11E7-9128-309100BA0AE3/iPadPro_12.9_10.3.3_14G60_Restore.ipsw" ;;
        "iPad_Pro_9.7")          bridge_url="http://appldnld.apple.com/ios10.3.3/091-23144-20170719-CA94A540-6977-11E7-85B4-2D9100BA0AE3/iPadPro_9.7_10.3.3_14G60_Restore.ipsw" ;;
        "iPad_Pro_10.5")         bridge_url="http://appldnld.apple.com/ios10.3.3/091-23306-20170719-CA9ADE92-6977-11E7-9D4A-379100BA0AE3/iPad_7,3_iPad_7,4_10.3.3_14G60_Restore.ipsw" ;;
        "iPad_Pro_12.9_2nd_Gen") bridge_url="http://appldnld.apple.com/ios10.3.3/091-23342-20170719-CA9AC9E8-6977-11E7-9507-3C9100BA0AE3/iPad_7,1_iPad_7,2_10.3.3_14G60_Restore.ipsw" ;;
        *) echo "No bridge URL available for $IPAD_MODEL. Attempting direct restore." ; return ;;
    esac

    # Recursively run the restore for the bridge firmware
    initiate_firmware_restore "$bridge_url"
}

initiate_firmware_restore() {
    local ipsw_path="$1"
    
    await_recovery_mode
    restrict_auto_boot
    parse_firmware_details "$ipsw_path"

    echo "Status: Preparing to install iOS $FIRMWARE_VER..."

    local session_dir="data/${IPAD_MODEL}_${SERIAL_NUM}/${FIRMWARE_VER}"
    mkdir -p "$session_dir/block"

    if [[ "$IS_A9_CHIP" == "true" ]]; then
        while ! ls "$session_dir"/block/*-restore-shcblock2.bin >/dev/null 2>&1; do
            echo "Step 1: Fetching Restore SHCBlock..."
            run_exploit_sequence

            if ! echo 1 | turdus_merula -C "$session_dir" --get-shcblock "$ipsw_path"; then
                echo "Warning: Block acquisition failed. Retrying exploit..."
                continue
            fi
            await_recovery_mode
            restrict_auto_boot
        done

        echo "Step 2: Installing firmware to iPad..."
        run_exploit_sequence

        until echo 1 | turdus_merula -C "$session_dir" -o --load-shcblock "$session_dir"/block/*-restore-shcblock2.bin "$ipsw_path"; do
            echo "Restore interrupted. Restarting exploit..."
            run_exploit_sequence
        done

        if [[ "$IS_PRELIMINARY_RESTORE" == "true" ]]; then
            return
        fi

        while ! ls "$session_dir"/block/*-current-shcblock2.bin >/dev/null 2>&1; do
            echo "Step 3: Fetching post-install SHCBlock..."
            ( cd "$session_dir" || exit; until turdusra1n -g "$ipsw_path"; do echo "Retrying block dump..."; done )
            await_recovery_mode
            restrict_auto_boot
        done

        while ! ls "$session_dir"/block/*-pteblock2.bin >/dev/null 2>&1; do
            echo "Step 4: Generating PTEBlock for tethered booting..."
            ( cd "$session_dir" || exit; until turdusra1n -g -i image4/*signed-SEP.img4 -C block/*-current-shcblock2.bin "$ipsw_path"; do echo "PTE Generation failed. Retrying..."; done )
            await_recovery_mode
            restrict_auto_boot
        done

    else
        echo "Step 1: Commencing A10/A10X Restore Sequence..."
        run_exploit_sequence

        until echo 1 | turdus_merula -C "$session_dir" -o "$ipsw_path"; do
            echo "Error during A10 restore. Re-exploiting..."
            run_exploit_sequence
        done
    fi
}

startup_ipad_system() {
    await_recovery_mode

    while irecovery -m 2>/dev/null | grep -q "Recovery Mode"; do
        echo "Guidance: If a 'failed to open handle' error appears, unplug and re-plug the USB cable."
        local base_path="data/${IPAD_MODEL}_${SERIAL_NUM}/${FIRMWARE_VER}"

        if [[ "$IS_A9_CHIP" == "true" ]]; then
            until turdusra1n -TP "$base_path"/block/*-pteblock2.bin; do
                echo "System failed to boot. Re-trying exploit..."
                sleep 1
            done
        else
            until turdusra1n -t "$base_path"/image4/*iBoot.img4 -i "$base_path"/image4/*signed-SEP.img4 -p "$base_path"/image4/*-SEP.im4p; do
                echo "System failed to boot. Re-trying exploit..."
                sleep 1
            done
        fi

        echo "Exploit payload sent. Waiting 20 seconds to verify system handoff..."
        sleep 20
    done

    echo "Status: iPad has successfully exited Recovery Mode."
}

write_tether_boot_script(){
    local script_name="boot_${IPAD_MODEL}_${FIRMWARE_VER}_${SERIAL_NUM}"
    rm -f *-"$SERIAL_NUM"

    # Define the payload conditionally based on the chip
    local exploit_cmd=""
    if [[ "$IS_A9_CHIP" == "true" ]]; then
        exploit_cmd="until turdusra1n -TP data/${IPAD_MODEL}_${SERIAL_NUM}/${FIRMWARE_VER}/block/*-pteblock2.bin; do echo 'Retrying exploit...'; done"
    else
        exploit_cmd="until turdusra1n -t data/${IPAD_MODEL}_${SERIAL_NUM}/${FIRMWARE_VER}/image4/*${BOOT_VER}-iBoot.img4 -i data/${IPAD_MODEL}_${SERIAL_NUM}/${FIRMWARE_VER}/image4/*signed-SEP.img4 -p data/${IPAD_MODEL}_${SERIAL_NUM}/${FIRMWARE_VER}/image4/*${BOOT_VER}-SEP.im4p; do echo 'Retrying exploit...'; done"
    fi

    # Write the script
    cat <<EOF > "$script_name"
#!/bin/bash
BASE_DIR="\$(cd "\$(dirname "\${BASH_SOURCE[0]}")" && pwd)"
cd "\$BASE_DIR"

# Import Paths
if [[ "\$(uname)" == "Linux" ]]; then
    if [[ "\$(uname -m)" == "x86_64" ]]; then
        PATH="\${PATH:+\$PATH:}\$BASE_DIR/bin:\$BASE_DIR/bin/Legacy-iOS-Kit/bin/linux/x86_64:\$BASE_DIR/bin/turdus_m3rula_1.1_b0ea3ee7_linux-amd64/bin"
    else
        PATH="\${PATH:+\$PATH:}\$BASE_DIR/bin:\$BASE_DIR/bin/Legacy-iOS-Kit/bin/linux/arm64:\$BASE_DIR/bin/turdus_m3rula_1.1_b0ea3ee7_linux-arm64/bin"
    fi
    [[ "\$EUID" -ne 0 ]] && echo "Run with sudo!" && exit 1
    killall usbmuxd >/dev/null 2>&1
    usbmuxd -p >/dev/null 2>&1
else
    PATH="\${PATH:+\$PATH:}\$BASE_DIR/bin:\$BASE_DIR/bin/Legacy-iOS-Kit/bin/macos:\$BASE_DIR/bin/turdus_m3rula_1.1_b0ea3ee7_macos/bin"
fi

while irecovery -m 2>/dev/null | grep -q "Recovery Mode"; do
    $exploit_cmd
    echo "Checking boot status in 20s..."
    sleep 20
done

killall usbmuxd > /dev/null 2>&1
usbmuxd
echo "Boot completed!"
EOF

    chmod 755 "$script_name"
    echo "Notice: If your iPad dies or restarts, run './$script_name' while connected to a PC to boot it."
}

# ============================================================
# 4. MAIN EXECUTION SEQUENCE
# ============================================================

# Command line parsing
if [[ "$1" == "-u" ]]; then
    if [[ "$#" -ne 2 ]]; then
        echo "Error: The -u argument requires the path to your old Samuel's downgrade folder."
        exit 1
    fi
    update_existing_data "$2"
    exit 0
fi

if [[ ! -f "$1" ]]; then
    echo -e "Error: Valid IPSW file required.\nUsage: ./samueldowngrade <path_to_ipsw>"
    exit 1
fi

# Execute workflow
set_path
startup
scan_for_ipad

# Check for intermediate restore
evaluate_prerequisite_restore "$1"

# Prepare for final restore
IS_PRELIMINARY_RESTORE=false
initiate_firmware_restore "$1"

# Boot and finalize
startup_ipad_system
write_tether_boot_script
refresh_usbmux

echo -e "\nSUCCESS! The downgrade process is complete.\n"

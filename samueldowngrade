#!/bin/bash

# ============================================================
# Samuel's iPad Downgrade - Main Execution Script
# Developed by: Samuel Bowers
# Version: 1.0
# ============================================================

SAM_VER="1.0"
BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$BASE_DIR"

# Initialize logging: captures all output and errors to session_log.txt
exec > >(tee session_log.txt) 2>&1

# Import the core device manipulation toolkit
if [ -f bin/idevice-tool-kit/idevice-tool-kit ]; then
    source bin/idevice-tool-kit/idevice-tool-kit
else
    echo "Fatal Error: idevice-tool-kit is missing from the bin folder."
    exit 1
fi

# Function to determine if a preliminary 10.3.3 restore is required
# This is specifically for early iOS 10 builds (10.0.1 through 10.3.2)
evaluate_prerequisite_restore() {
    local ipsw_path="$1"
    get_ver "$ipsw_path"

    case "$ver" in
        "10.0.1_14A403" | "10.0.2_14A456" | "10.0.3_14A551" | \
        "10.1_14B72c"   | "10.1.1_14B100" | "10.1.1_14B150" | \
        "10.2_14C92"    | "10.2.1_14D27"  | "10.3_14E277"   | \
        "10.3.1_14E304" | "10.3.2_14F89")
            echo "Status: Early iOS 10 detected. Initiating bridge restore to iOS 10.3.3."
            ;;
        *)
            # No intermediate restore needed
            return
            ;;
    esac

    # Assign the correct 10.3.3 URL based on the detected hardware
    local bridge_url=""
    case "$device" in
        "iphone_6s")      bridge_url="http://appldnld.apple.com/ios10.3.3/091-23441-20170719-CA9B0570-6977-11E7-95CC-3F9100BA0AE3/iPhone_4.7_10.3.3_14G60_Restore.ipsw" ;;
        "iphone_6s_plus") bridge_url="http://appldnld.apple.com/ios10.3.3/091-23338-20170719-CA990FD6-6977-11E7-AE41-3B9100BA0AE3/iPhone_5.5_10.3.3_14G60_Restore.ipsw" ;;
        "iphone_se")      bridge_url="http://appldnld.apple.com/ios10.3.3/091-23133-20170719-CA8E78E6-6977-11E7-968B-2B9100BA0AE3/iPhone_4.0_64bit_10.3.3_14G60_Restore.ipsw" ;;
        "iphone_7")       bridge_url="http://appldnld.apple.com/ios10.3.3/091-23304-20170719-CA9AC9AC-6977-11E7-9507-349100BA0AE3/iPhone_7_10.3.3_14G60_Restore.ipsw" ;;
        "iphone_7_plus")  bridge_url="http://appldnld.apple.com/ios10.3.3/091-23119-20170719-CA92905C-6977-11E7-AB61-299100BA0AE3/iPhone_7Plus_10.3.3_14G60_Restore.ipsw" ;;
        *) echo "Error: Device type '$device' not recognized for bridge restore."; exit 1 ;;
    esac

    restore_ipsw "$bridge_url"
}

# Branding display
echo "------------------------------------------------"
echo " Samuel's iPad Downgrade Utility v$SAM_VER"
echo " Based on Dusk Downgrade (3-BSD License)"
echo " Maintained by: Samuel Bowers"
echo "------------------------------------------------"

# Handle update requests
if [[ "$1" == "-u" ]]; then
    if [[ -z "$2" ]]; then
        echo "Error: The -u flag requires a path to a previous release folder."
        exit 1
    fi
    echo "Migrating data from existing installation..."
    update_existing_data "$2"
    exit 0
fi

# Validate input IPSW
if [[ ! -f "$1" ]]; then
    echo "Error: Please provide a valid .ipsw file path."
    echo "Usage: ./samuel-downgrade <file.ipsw>"
    exit 1
fi

# Main Sequence
set_path
startup
detect_iphone

# Check if we need the 10.3.3 jump
evaluate_prerequisite_restore "$1"

# Proceed to final target restore
echo "Beginning final downgrade process..."
not_final_restore=false
restore_ipsw "$1"

# Device booting and finalization
boot_turdusra1n
generate_boot_script
usbmuxd_restart

echo -e "\nProcess Complete! Your device has been downgraded.\n"

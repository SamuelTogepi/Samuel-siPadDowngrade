#!/bin/bash

# ============================================================
# Build Script for Samuel's iPad Downgrade
# Author: Samuel Bowers
# Description: Automates the packaging and versioning process.
# ============================================================

set -e

# Configuration
APP_VER="2.0.4"
BIN_NAME="samuel-downgrade" # Ensure your main script is renamed to this
ARCHIVE_NAME="samuels-ipad-downgrade-v$APP_VER"

# Navigate to the directory where this script is located
PROJECT_ROOT="$(cd "$(dirname "$0")" && pwd)"
cd "$PROJECT_ROOT"

# Cleanup previous builds
echo "Cleaning up old build files..."
rm -rf "$ARCHIVE_NAME" "$ARCHIVE_NAME.zip"

# If user passed 'clean' argument, stop here
if [[ "$1" == "clean" ]]; then
    echo "Workspace cleared."
    exit 0
fi

# Create distribution folder
mkdir -p "$ARCHIVE_NAME"

# Determine if we are using GNU sed (Linux) or BSD sed (macOS)
# to handle version string replacement correctly.
if sed --version >/dev/null 2>&1; then
    # Linux / GNU Logic
    echo "System detection: GNU Environment"
    sed -i -E "s/^version=.*/version=\"$APP_VER\"/" "$BIN_NAME"
else
    # macOS / BSD Logic
    echo "System detection: BSD Environment"
    sed -i '' -E "s/^version=.*/version=\"$APP_VER\"/" "$BIN_NAME"
fi

# Define the list of items to include in the release
# (Main script, binary folder, and all documentation)
COMPONENTS=("$BIN_NAME" "bin" *.md)

echo "Staging files for release..."
for item in "${COMPONENTS[@]}"; do
    cp -r "$item" "$ARCHIVE_NAME/"
done

# Standardize permissions for the release folder
chmod -R 755 "$ARCHIVE_NAME"

# Compress into a portable ZIP archive
echo "Generating $ARCHIVE_NAME.zip..."
zip -r "$ARCHIVE_NAME.zip" "$ARCHIVE_NAME"

echo "Build Process Finished Successfully."

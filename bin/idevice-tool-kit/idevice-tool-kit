#!/bin/bash

# ============================================================
# Samuel's iPad Downgrade: Core Logic & Device Toolkit
# Description: Handles low-level device communication and exploits
# ============================================================

# Define Global Configuration
SYS_OS="$(uname)"
SYS_ARCH="$(uname -m)"
IPAD_MODEL=""
IS_A9_CHIP=false
FIRMWARE_VER=""
SERIAL_NUM=""
IS_IN_RECOVERY=false
TARGET_IPSW=""
SIGNED_RESTORE_ACTIVE=false
PRELIMINARY_PHASE=true

# --- Daemon Management ---

refresh_usbmux() {
    # Resets the usbmuxd daemon to ensure clean communication
    killall usbmuxd > /dev/null 2>&1
    usbmuxd > /dev/null 2>&1
    echo "Communication daemon (usbmuxd) has been refreshed."
}

# --- Data Management ---

sync_existing_assets() {
    local source_dir="$1"
    if [[ -d "$source_dir/data" ]]; then
        echo "Valid data directory located at $source_dir."
        cp -rv "$source_dir/data" .
        echo "Data migration successful."
    else
        echo "Critical Error: Path '$source_dir' does not contain a data folder."
        exit 1
    fi

    # Migrate any existing boot scripts without erroring if none exist
    cp -rv "$source_dir"/boot-* . 2>/dev/null 
}

# --- Environment Setup ---

initialize_env() {
    # Dynamically build the system PATH based on OS and Architecture
    local bin_base="$real_portable_folder/bin"
    local legacy_base="$bin_base/Legacy-iOS-Kit/bin"
    local turdus_base=""

    if [[ "$SYS_OS" == "Linux" ]]; then
        case "$SYS_ARCH" in
            "x86_64") turdus_base="$bin_base/turdus_m3rula_1.3_1fc7203b_linux-amd64/bin"
                      PATH="${PATH:+$PATH:}$bin_base:$legacy_base/linux/x86_64:$turdus_base" ;;
            "arm64")  turdus_base="$bin_base/turdus_m3rula_1.3_1fc7203b_linux-arm64/bin"
                      PATH="${PATH:+$PATH:}$bin_base:$legacy_base/linux/arm64:$turdus_base" ;;
            *) echo "Error: $SYS_ARCH architecture is not supported on Linux."; exit 1 ;;
        esac
    elif [[ "$SYS_OS" == "Darwin" ]]; then
        turdus_base="$bin_base/turdus_m3rula_1.3_1fc7203b_macos/bin"
        PATH="${PATH:+$PATH:}$bin_base:$legacy_base/macos:$turdus_base"
    else
        echo "Error: Operating system $SYS_OS is unsupported."
        exit 1
    fi
}

setup_workspace() {
    # Initialize directory structure
    [[ ! -d "data" ]] && mkdir "data" && echo "Workspace initialized." || echo "Existing data found."
    mkdir -p "data/ipsw."

    # Permission checks for Linux
    if [[ "$SYS_OS" == "Linux" ]]; then
        [[ "$EUID" -ne 0 ]] && echo "Please run as root (sudo) on Linux." && exit 1
    fi

    # Resource check for Legacy-iOS-Kit
    if [[ ! -f "bin/Legacy-iOS-Kit/resources/firstrun" ]]; then
        (cd bin/Legacy-iOS-Kit && ./restore.sh --no-version-check --no-internet-check)
        
        if [[ "$SYS_OS" == "Linux" ]]; then
            if command -v dnf >/dev/null; then
                dnf install -y libimobiledevice libimobiledevice-utils expect idevicerestore irecovery
                update-crypto-policies --set LEGACY > /dev/null 2>&1
            elif command -v apt >/dev/null; then
                apt update && apt install -y expect libimobiledevice libimobiledevice-utils idevicerestore irecovery
            fi
        fi
        echo "Dependencies installed. Reconnect your iPad and press Enter."
        read -r
    fi

    # Security policy adjustments
    if [[ "$SYS_OS" == "Linux" && -x "$(command -v dnf)" ]]; then
        update_crypto_policies --set LEGACY > /dev/null 2>&1
        setenforce 0 2>/dev/null
    elif [[ "$SYS_OS" == "Darwin" ]]; then
        xattr -rc . # Clear macOS quarantine flags
    fi
}

# --- Boot Management ---

write_tether_boot_script() {
    local script_name="boot_${IPAD_MODEL}_${FIRMWARE_VER}_${SERIAL_NUM}"
    rm -f *-"$SERIAL_NUM" # Clean old scripts for this specific device

    local payload=""
    if [[ "$IS_A9_CHIP" == "true" ]]; then
        # A9 logic: PTEblock boot
        payload='while irecovery -m 2>/dev/null | grep -q "Recovery Mode"; do
            until turdusra1n -TP data/'$IPAD_MODEL'_'$SERIAL_NUM'/'$FIRMWARE_VER'/block/*-pteblock2.bin; do 
                echo "Retrying exploit..."
            done
            sleep 20
        done'
    else
        # A10 logic: SEP/iBoot image4 boot
        payload='while irecovery -m 2>/dev/null | grep -q "Recovery Mode"; do
            until turdusra1n -t data/'$IPAD_MODEL'_'$SERIAL_NUM'/'$FIRMWARE_VER'/image4/*iBoot.img4 -i data/'$IPAD_MODEL'_'$SERIAL_NUM'/'$FIRMWARE_VER'/image4/*signed-SEP.img4 -p data/'$IPAD_MODEL'_'$SERIAL_NUM'/'$FIRMWARE_VER'/image4/*SEP.im4p; do
                echo "Retrying exploit..."
            done
            sleep 20
        done'
    fi

    # Wrap payload in script boilerplate
    echo -e "#!/bin/bash\n# Samuel's iPad Bootstrapper\n$(declare -f initialize_env)\ninitialize_env\n$payload\nrefresh_usbmux\necho 'Boot Complete.'" > "$script_name"
    chmod +x "$script_name"
    echo "Generated boot script: $script_name."
}

# --- Device Detection ---

identify_connected_device() {
    echo "Scanning for A9/A10 iPad..."

    # Block until device leaves DFU if necessary
    if irecovery -m 2>/dev/null | grep -q "DFU Mode"; then
        echo "Detected DFU state. Moving to recovery handler..."
        await_recovery_mode
    fi

    while true; do
        if irecovery -m 2>/dev/null | grep -q "Recovery Mode"; then
            echo "Device found in Recovery Mode."
            IS_IN_RECOVERY=true
            SERIAL_NUM=$(irecovery -q 2>/dev/null | grep 'SRNM:' | cut -d ' ' -f2)
            local product=$(irecovery -q 2>/dev/null | grep 'PRODUCT:' | cut -d ' ' -f2)
            
            case "$product" in
                "iPad6,11"|"iPad6,12") IPAD_MODEL="ipad_5" ;;
                "iPad7,5"|"iPad7,6")   IPAD_MODEL="ipad_6" ;;
                "iPad6,7"|"iPad6,8")   IPAD_MODEL="ipad_pro_129_1" ;;
                "iPad6,3"|"iPad6,4")   IPAD_MODEL="ipad_pro_97" ;;
                "iPad7,3"|"iPad7,4")   IPAD_MODEL="ipad_pro_105" ;;
                "iPad7,1"|"iPad7,2")   IPAD_MODEL="ipad_pro_129_2" ;;
                *) echo "Incompatible device: $product"; exit 1 ;;
            esac
            
            # Check Chip ID
            local cpid=$(irecovery -q 2>/dev/null | grep 'CPID:' | cut -d ' ' -f2)
            [[ "$cpid" == "0x8003" || "$cpid" == "0x8000" ]] && IS_A9_CHIP=true
            break
        else
            # Try Normal Mode
            idevicepair pair >/dev/null 2>&1
            SERIAL_NUM=$(ideviceinfo -k SerialNumber 2>/dev/null)
            [[ -z "$SERIAL_NUM" ]] && sleep 2 && continue
            
            local type=$(ideviceinfo -k ProductType 2>/dev/null)
            case "$type" in
                "iPad6,11"|"iPad6,12") IPAD_MODEL="ipad_5" ;;
                "iPad7,5"|"iPad7,6")   IPAD_MODEL="ipad_6" ;;
                *) echo "Standard mode detection for $type failed. Put device in Recovery."; exit 1 ;;
            esac
            break
        fi
    done
    echo "Detected: $IPAD_MODEL | Serial: $SERIAL_NUM | A9: $IS_A9_CHIP"
}

# --- Restore Logic ---

execute_restore() {
    local target_ipsw="$1"
    parse_firmware_details "$target_ipsw"
    
    echo "Initiating restore for $FIRMWARE_VER..."
    local work_dir="data/${IPAD_MODEL}_${SERIAL_NUM}/${FIRMWARE_VER}"
    mkdir -p "$work_dir"

    if [[ "$IS_A9_CHIP" == "true" ]]; then
        # A9 Restore Cycle (SHC/PTE Blocks)
        while ! find "$work_dir/block" -name "*restore-shcblock2.bin" | grep -q .; do
            trigger_exploit
            turdus_merula -C "$work_dir" --get-shcblock "$target_ipsw" || continue
            await_recovery_mode
        done

        trigger_exploit
        turdus_merula -C "$work_dir" -o --load-shcblock "$work_dir"/block/*-restore-shcblock2.bin "$target_ipsw"
    else
        # A10 Restore Cycle
        trigger_exploit
        turdus_merula -C "$work_dir" -o "$target_ipsw"
    fi
}

# --- Helper Utilities ---

await_recovery_mode() {
    until irecovery -m 2>/dev/null | grep -q "Recovery Mode"; do
        if irecovery -m 2>/dev/null | grep -q "DFU Mode"; then
            echo "Manually exit DFU Mode using the button combination for your iPad model."
        fi
        sleep 1
    done
}

trigger_exploit() {
    until turdusra1n -D; do
        echo "Exploit failed. Re-attempting..."
        sleep 1
    done
}

parse_firmware_details() {
    FIRMWARE_VER=$(echo "$1" | sed -E 's/.*_(.*_.*)_Restore\.ipsw/\1/')
}
